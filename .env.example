# Copy to ~/.config/neura/cli.env or export before running demos

NEURA_SERVER_URL=https://gateway.datapro.asia
NEURA_API_KEY=gw-your-key-from-neuradesk-settings

# Optional — repo ensure / private clones
# GITHUB_TOKEN=ghp_…

# Optional — connector list local catalog
# NEURA_PLUGIN_BUNDLE_ROOT=/path/to/llm-gateway/plugins
